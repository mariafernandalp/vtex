{
  "$extends": [
    "#/$defs/base-component"
  ],
  "$componentKey": "PhotoGrid",
  "$componentTitle": "Grade de Fotos",
  "type": "object",
  "required": [
    "photos"
  ],
  "properties": {
    "sectionTitle": {
      "title": "Título da Seção (Opcional)",
      "type": "string"
    },
    "sectionSubtitle": {
      "title": "Subtítulo da Seção (Opcional)",
      "type": "string"
    },
    "layout": {
      "title": "Layout",
      "type": "string",
      "default": "vertical",
      "enum": ["vertical", "horizontal"],
      "enumNames": ["Vertical (3:4, até 4 fotos)", "Horizontal (4:3, até 2 fotos)"]
    },
    "photos": {
      "title": "Fotos",
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "title": "Foto",
        "required": ["image"],
        "properties": {
          "image": {
            "title": "Imagem",
            "type": "string",
            "widget": {
              "ui:widget": "media-gallery"
            }
          },
          "title": {
            "title": "Título (aparece ao passar o mouse)",
            "type": "string"
          },
          "linkUrl": {
            "title": "Link de Destino",
            "type": "string"
          }
        }
      }
    }
  },
  "if": {
    "properties": {
      "layout": { "const": "horizontal" }
    }
  },
  "then": {
    "properties": {
      "photos": {
        "maxItems": 2
      }
    }
  },
  "else": {
    "properties": {
      "photos": {
        "maxItems": 4
      }
    }
  }
}
