{
  "$extends": [
    "#/$defs/base-component"
  ],
  "$componentKey": "ThreeCards",
  "$componentTitle": "Três Cards",
  "type": "object",
  "required": [
    "cards"
  ],
  "properties": {
    "sectionTitle": {
      "title": "Título da Seção (Opcional)",
      "type": "string"
    },
    "sectionSubtitle": {
      "title": "Subtítulo da Seção (Opcional)",
      "type": "string"
    },
    "cards": {
      "title": "Cards",
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "title": "Card",
        "required": ["image", "title", "description", "buttonText"],
        "properties": {
          "image": {
            "title": "Imagem do Card (Quadrada)",
            "type": "string",
            "widget": {
              "ui:widget": "media-gallery"
            }
          },
          "title": {
            "title": "Título (Negrito)",
            "type": "string"
          },
          "description": {
            "title": "Descrição (Breve frase)",
            "type": "string"
          },
          "buttonText": {
            "title": "Texto do Botão (Chamada para ação)",
            "type": "string"
          },
          "buttonIcon": {
            "title": "Ícone do Botão (Lucide React, ex: ArrowRight, Star, etc)",
            "type": "string"
          },
          "linkUrl": {
            "title": "Link de Destino",
            "type": "string"
          }
        }
      }
    }
  }
}
