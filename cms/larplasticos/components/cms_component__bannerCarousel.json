{
  "$extends": [
    "#/$defs/base-component"
  ],
  "$componentKey": "CarouselBanner",
  "$componentTitle": "Carrossel de Banners",
  "type": "object",
  "required": [
    "banners"
  ],
  "properties": {
    "banners": {
      "title": "Lista de Banners",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "title": "Slide do Banner",
        "required": ["title", "imageUrl"],
        "properties": {
          "title": {
            "title": "Título / Alt da Imagem",
            "type": "string"
          },
          "imageUrl": {
            "title": "Imagem do Banner (Desktop)",
            "type": "string",
            "widget": {
              "ui:widget": "media-gallery"
            }
          },
          "imageUrlMobile": {
            "title": "Imagem do Banner (Mobile)",
            "type": "string",
            "widget": {
              "ui:widget": "media-gallery"
            }
          },
          "linkUrl": {
            "title": "Link de Destino (Opcional)",
            "type": "string"
          }
        }
      }
    }
  }
}
